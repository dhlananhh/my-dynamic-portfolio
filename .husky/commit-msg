#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "📝 Checking commit message format..."

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Regex for Conventional Commits: type(scope?): subject
conventional_regex="^(feat|fix|docs|style|refactor|perf|test|chore)(\([a-z0-9\-]+\))?: .{1,}$"

if ! echo "$commit_msg" | grep -Eq "$conventional_regex"; then
  echo "❌ Invalid commit message format!"
  echo "Commit message must follow Conventional Commits, e.g.:"
  echo "  feat(auth): add login functionality"
  echo "  fix(api): handle null values"
  echo "  docs(readme): update installation guide"
  exit 1
fi

echo "✅ Commit message format is valid."
